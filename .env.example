# AI Agent Olympics — environment variables
# Copy to .env and fill in your own values. Never commit .env.

# Login gate — comma-separated shared keys. Empty = auth disabled (open mode).
# Generate keys with: openssl rand -base64 24
AUTH_KEYS=

# LLM provider key (Gemini default)
LLM_API_KEY=

# GEM² platform key — required for /api/audit-gate/p-check and /api/audit-gate/o-check
# (proxies to https://gem2-tpmn-checker.fly.dev). Provision at https://user-mgmt.gemsquared.ai.
# Also used by legacy /api/audit and /api/compliance (truth-filter scoring).
GEM2_API_KEY=

# Optional override for audit-gate base URL (default: https://gem2-tpmn-checker.fly.dev)
# Use https://gem2-tpmn-checker-staging.fly.dev for staging.
# GEM2_GATE_URL=

# Optional — extra LLM providers
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VULTR_INFERENCE_API_KEY=

# Headless-caller LLM defaults — used ONLY when chat requests omit `model` /
# `agent_model` fields. The UI dropdowns dominate when present. Hackathon
# default is gemini-2.5-flash for both orchestrator and agent roles.
GEM2_DEFAULT_LLM=gemini-2.5-flash
GEM2_DEFAULT_AGENT_LLM=gemini-2.5-flash

# Port for the HTTP server (default 8090 in code; 8080 on the Vultr VPS via systemd)
# PORT=8090

# Override the project working directory (default: cwd)
# PROJECT_DIR=
